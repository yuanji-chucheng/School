# 阿里云OSS配置模板
# 项目组成员请按照以下步骤配置：

# 1. 复制此文件，并重命名为 application-local.yml
# 2. 联系项目负责人获取阿里云AccessKey
# 3. 将下面的占位符替换为真实的AccessKey
# 4. 确保文件位置在 src/main/resources/ 目录下
# 5. 启动项目即可使用OSS上传功能

aliyun:
  oss:
    enabled: true
    endpoint: oss-cn-hangzhou.aliyuncs.com
    access-key-id: 请联系项目负责人获取AccessKey-ID
    access-key-secret: 请联系项目负责人获取AccessKey-Secret
    bucket-name: congrongyingdui

# 配置完成后，上传的图片会自动存储到阿里云OSS
# 所有团队成员上传的图片都会存储在同一个Bucket中，实现共享